# X(Twitter)MCP 凭证。复制为 .env 并填入真实值(.env 不入库)。
#
# 重要:本工程只【读】X(读名人推文/搜索),实际只用 Bearer Token。
# 但 x-mcp server 启动时强制要求 5 个变量都【非空】(空串也算缺)。
# 因此:填你拥有的 3 个真实值;Access Token/Secret(仅发推等写操作用)保持下面的占位即可。
#
# 用前:在启动 Claude Code / 该 agent 的 shell 里执行:
#   set -a; source .env; set +a
# 这样 .mcp.json 里的 ${X_*} 占位才会被展开并注入 server。

# ——【需要你填】读取所需的 3 个(来自 X 开发者后台 → Keys and tokens)——
X_API_KEY=          # = Consumer Key / API Key(你说的 consumer token)
X_API_SECRET=       # = Consumer Secret / API Secret
X_BEARER_TOKEN=     # 读取实际只用它

# ——【只读可不填,保持占位】仅写操作需要;留非空占位让 server 能启动 ——
X_ACCESS_TOKEN=unused
X_ACCESS_TOKEN_SECRET=unused
